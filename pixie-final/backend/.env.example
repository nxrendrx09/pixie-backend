# ── Pixie Environment Variables ──────────────────────────────────────────────
# Rename this file to .env and fill in your values
# NEVER share this file or push it to GitHub

# ── Gemini AI (FREE) ──────────────────────────────────────────────────────────
# Get from: https://aistudio.google.com → Get API Key → Create API Key
GEMINI_API_KEY=your_gemini_api_key_here

# ── ElevenLabs Voice ──────────────────────────────────────────────────────────
# Get from: https://elevenlabs.io → Profile icon → API Keys
ELEVENLABS_API_KEY=your_elevenlabs_key_here

# Voice ID — go to elevenlabs.io/voice-library, search "Indian female"
# Click a voice → the ID is in the URL: /voice-lab/voice/VOICE_ID_HERE
# Default below is a good Indian female voice — replace with your preferred one
ELEVENLABS_VOICE_ID=XB0fDUnXU5powFXDhCwa

# ── MongoDB Atlas (FREE) ──────────────────────────────────────────────────────
# Get from: mongodb.com/atlas → New Project → Free Cluster → Connect → Drivers
# Replace <username>, <password>, and <cluster> with your actual values
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/pixie?retryWrites=true&w=majority

# ── Render (set automatically — DO NOT touch) ─────────────────────────────────
# Render sets this automatically when deployed. Leave blank locally.
# RENDER_EXTERNAL_URL=https://pixie-backend.onrender.com
