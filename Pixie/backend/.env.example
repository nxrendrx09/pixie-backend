# ─── Pixie Backend Environment Variables ───────────────────────────────────────
# Copy this file to .env and fill in your values

# Get from: https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_key_here

# Get from: https://elevenlabs.io → Profile → API Key
ELEVENLABS_API_KEY=your_elevenlabs_key_here

# ElevenLabs Voice ID for Indian female voice
# Default below works — or pick one from elevenlabs.io/voice-library
ELEVENLABS_VOICE_ID=XB0fDUnXU5powFXDhCwa

# Get from: https://mongodb.com/atlas → Connect → Driver
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/pixie

# Port (Railway sets this automatically)
PORT=3001
